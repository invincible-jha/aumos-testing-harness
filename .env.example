# ============================================================================
# aumos-testing-harness — Environment Variables
# ============================================================================
# Copy to .env for local development. Never commit .env to version control.
# All variables use the AUMOS_TESTHARNESS_ prefix.
# Standard AumOS vars (database, kafka, keycloak) are inherited from aumos-common.
# ============================================================================

# --- Standard AumOS Settings (inherited from aumos-common) ---
AUMOS_DATABASE_URL=postgresql+asyncpg://aumos:aumos_dev@localhost:5432/aumos
AUMOS_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
AUMOS_KEYCLOAK_SERVER_URL=http://localhost:8080
AUMOS_KEYCLOAK_REALM=aumos
AUMOS_KEYCLOAK_CLIENT_ID=aumos-testing-harness
AUMOS_KEYCLOAK_CLIENT_SECRET=change-me-in-production
AUMOS_ENVIRONMENT=development
AUMOS_LOG_LEVEL=INFO

# --- LLM Provider Configuration ---
# API keys for LLM evaluation backends
AUMOS_TESTHARNESS_OPENAI_API_KEY=sk-...
AUMOS_TESTHARNESS_OPENAI_MODEL=gpt-4o
AUMOS_TESTHARNESS_ANTHROPIC_API_KEY=sk-ant-...
AUMOS_TESTHARNESS_ANTHROPIC_MODEL=claude-opus-4-6
AUMOS_TESTHARNESS_AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AUMOS_TESTHARNESS_AZURE_OPENAI_API_KEY=
AUMOS_TESTHARNESS_AZURE_OPENAI_DEPLOYMENT=gpt-4o

# --- Evaluation Framework Settings ---
# Default pass threshold for LLM metrics (0.0–1.0)
AUMOS_TESTHARNESS_DEFAULT_PASS_THRESHOLD=0.7
# Maximum concurrent evaluation workers
AUMOS_TESTHARNESS_MAX_EVAL_WORKERS=4
# Evaluation timeout in seconds
AUMOS_TESTHARNESS_EVAL_TIMEOUT_SECONDS=300
# RAGAS evaluation batch size
AUMOS_TESTHARNESS_RAGAS_BATCH_SIZE=10

# --- Red-Team / OWASP Settings ---
# Garak runner configuration
AUMOS_TESTHARNESS_GARAK_ENABLED=true
AUMOS_TESTHARNESS_GARAK_PROBES=encoding,knownbadsignatures,leakage,packagehallucination
# Giskard scan configuration
AUMOS_TESTHARNESS_GISKARD_ENABLED=true
# Maximum number of red-team attack attempts per category
AUMOS_TESTHARNESS_RED_TEAM_MAX_ATTEMPTS=50
# Red-team report retention days
AUMOS_TESTHARNESS_RED_TEAM_REPORT_RETENTION_DAYS=90

# --- Agent Evaluation Settings ---
AUMOS_TESTHARNESS_AGENT_EVAL_TIMEOUT_SECONDS=600
AUMOS_TESTHARNESS_AGENT_MAX_STEPS=20

# --- Storage ---
# S3-compatible bucket for storing large test artifacts and reports
AUMOS_TESTHARNESS_ARTIFACT_BUCKET=aumos-test-artifacts
AUMOS_TESTHARNESS_ARTIFACT_BUCKET_REGION=us-east-1
AUMOS_TESTHARNESS_AWS_ACCESS_KEY_ID=
AUMOS_TESTHARNESS_AWS_SECRET_ACCESS_KEY=

# --- CI/CD Integration ---
AUMOS_TESTHARNESS_WEBHOOK_SECRET=change-me-in-production
AUMOS_TESTHARNESS_GITHUB_TOKEN=
